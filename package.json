{
  "name": "@stargiraffe/annotator",
  "version": "1.0.0",
  "description": "React text highlighting & annotation library with localStorage persistence",
  "license": "MIT",
  "author": "Your Name",
  "keywords": [
    "react",
    "highlight",
    "annotation",
    "text",
    "markup",
    "comments"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components.esm.js",
      "require": "./dist/components.cjs.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.esm.js",
      "require": "./dist/hooks.cjs.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.esm.js",
      "require": "./dist/types.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage.esm.js",
      "require": "./dist/storage.cjs.js",
      "types": "./dist/storage/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyusungpark/annotator.git"
  },
  "bugs": {
    "url": "https://github.com/kyusungpark/annotator/issues"
  },
  "homepage": "https://github.com/kyusungpark/annotator#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*\"",
    "test": "vitest",
    "prepublishOnly": "npm run build && npm run type-check"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "nanoid": "^5.0.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-context-menu": "^2.2.14",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "clsx": "^2.0.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.263.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
